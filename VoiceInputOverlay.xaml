<Window x:Class="MouseClickVoice.VoiceInputOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VoiceInputOverlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        ShowActivated="False"
        SizeToContent="WidthAndHeight">
    <Border x:Name="CapsuleBorder"
            Background="#F2000000"
            CornerRadius="22"
            Padding="18,11"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.45" Color="Black"/>
        </Border.Effect>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock x:Name="StatusText"
                       Text="语音输入"
                       Foreground="White"
                       FontSize="14"
                       FontWeight="Medium"
                       VerticalAlignment="Center"/>
            <Rectangle Width="1"
                       Height="16"
                       Fill="#55FFFFFF"
                       Margin="14,0"
                       VerticalAlignment="Center"/>
            <StackPanel x:Name="WaveformPanel"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Height="20">
                <Rectangle x:Name="Bar1" Width="3" RadiusX="1.5" RadiusY="1.5" Fill="White"
                           Height="8" VerticalAlignment="Center" Margin="0,0,3,0"/>
                <Rectangle x:Name="Bar2" Width="3" RadiusX="1.5" RadiusY="1.5" Fill="White"
                           Height="12" VerticalAlignment="Center" Margin="0,0,3,0"/>
                <Rectangle x:Name="Bar3" Width="3" RadiusX="1.5" RadiusY="1.5" Fill="White"
                           Height="6" VerticalAlignment="Center" Margin="0,0,3,0"/>
                <Rectangle x:Name="Bar4" Width="3" RadiusX="1.5" RadiusY="1.5" Fill="White"
                           Height="14" VerticalAlignment="Center"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
