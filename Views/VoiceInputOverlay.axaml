<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MouseClickVoice.VoiceInputOverlay"
        Title="VoiceInputOverlay"
        SystemDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False"
        Focusable="False"
        CanResize="False"
        SizeToContent="WidthAndHeight">
    <Border x:Name="CapsuleBorder"
            Background="#F2000000"
            CornerRadius="22"
            Padding="18,11"
            BoxShadow="0 0 16 0 #73000000">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock x:Name="StatusText"
                       Text="语音输入"
                       Foreground="White"
                       FontSize="14"
                       FontWeight="Medium"
                       VerticalAlignment="Center"/>
            <Border Width="1"
                    Height="16"
                    Background="#55FFFFFF"
                    Margin="14,0"
                    VerticalAlignment="Center"/>
            <StackPanel x:Name="WaveformPanel"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Height="20">
                <Border x:Name="Bar1" Width="3" CornerRadius="1.5" Background="White"
                        Height="8" VerticalAlignment="Center" Margin="0,0,3,0"/>
                <Border x:Name="Bar2" Width="3" CornerRadius="1.5" Background="White"
                        Height="12" VerticalAlignment="Center" Margin="0,0,3,0"/>
                <Border x:Name="Bar3" Width="3" CornerRadius="1.5" Background="White"
                        Height="6" VerticalAlignment="Center" Margin="0,0,3,0"/>
                <Border x:Name="Bar4" Width="3" CornerRadius="1.5" Background="White"
                        Height="14" VerticalAlignment="Center"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
