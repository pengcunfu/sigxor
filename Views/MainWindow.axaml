<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MouseClickVoice.MainWindow"
        Title="语音输入" Height="480" Width="400"
        MinWidth="400" MinHeight="480"
        WindowStartupLocation="CenterScreen"
        Icon="/icon.png">
    <Grid Margin="10">
        <TabControl x:Name="MainTabControl">
            <TabItem Header="服务">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <Button x:Name="StartServiceButton" Content="开始服务" Width="96" Margin="0,0,8,0"
                                Click="StartServiceButton_Click"/>
                        <Button x:Name="StopServiceButton" Content="停止服务" Width="96" IsEnabled="False"
                                Click="StopServiceButton_Click"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1">
                        <TextBlock Text="状态" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="快捷键:" Width="80"/>
                            <TextBlock x:Name="ShortcutStatusText" Text="等待中..." Foreground="Gray"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="录音状态:" Width="80"/>
                            <TextBlock x:Name="RecordingStatusText" Text="未开始" Foreground="Gray"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="识别状态:" Width="80" VerticalAlignment="Center"/>
                            <TextBlock x:Name="RecognitionStatusText" Text="未启动" Foreground="Gray" VerticalAlignment="Center"/>
                            <Button x:Name="DownloadModelButton" Content="下载" Margin="8,0,0,0" Padding="8,2"
                                    IsVisible="False" Click="DownloadModelButton_Click"/>
                            <Button x:Name="OpenModelFolderButton" Content="打开模型目录" Margin="8,0,0,0" Padding="8,2"
                                    IsVisible="False" Click="OpenModelFolderButton_Click"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="最后识别:" Width="80"/>
                            <TextBlock x:Name="LastRecognizedText" Text="无" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Grid.Row="2" Text="使用说明：右 Alt 短按开始/再按结束（长录音），或按住右 Alt 松手结束（短句）"
                               FontSize="12" Foreground="Gray"
                               TextWrapping="Wrap" Margin="0,12,0,0"/>
                </Grid>
            </TabItem>

            <TabItem Header="设置">
                <ScrollViewer Margin="0,8,0,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,8" ColumnDefinitions="80,*">
                            <TextBlock Grid.Column="0" Text="识别引擎:" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" x:Name="EngineComboBox" HorizontalAlignment="Stretch"
                                      SelectionChanged="EngineComboBox_SelectionChanged"/>
                        </Grid>
                        <Grid Margin="0,0,0,8" ColumnDefinitions="80,*">
                            <TextBlock Grid.Column="0" Text="识别语言:" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" x:Name="LanguageComboBox" HorizontalAlignment="Stretch"
                                      SelectionChanged="LanguageComboBox_SelectionChanged">
                                <ComboBoxItem Content="中文" Tag="zh-CN" IsSelected="True"/>
                                <ComboBoxItem Content="English" Tag="en-US"/>
                                <ComboBoxItem Content="粤语" Tag="yue"/>
                                <ComboBoxItem Content="日语" Tag="ja"/>
                                <ComboBoxItem Content="韩语" Tag="ko"/>
                                <ComboBoxItem Content="自动" Tag="auto"/>
                            </ComboBox>
                        </Grid>
                        <CheckBox x:Name="ShowNotificationsCheckBox" Content="显示通知"
                                  Margin="0,0,0,5" Checked="ShowNotificationsCheckBox_Changed"
                                  Unchecked="ShowNotificationsCheckBox_Changed"/>
                        <CheckBox x:Name="UseClipboardCheckBox" Content="使用剪贴板粘贴"
                                  Margin="0,0,0,5" Checked="UseClipboardCheckBox_Changed"
                                  Unchecked="UseClipboardCheckBox_Changed"/>
                        <CheckBox x:Name="SilentStartCheckBox" Content="开机自启动时静默（仅托盘，不显示窗口）"
                                  Margin="0,0,0,5" Checked="SilentStartCheckBox_Changed"
                                  Unchecked="SilentStartCheckBox_Changed"/>
                        <CheckBox x:Name="MinimizeToTrayCheckBox" Content="关闭窗口时最小化到托盘"
                                  Margin="0,0,0,5" Checked="MinimizeToTrayCheckBox_Changed"
                                  Unchecked="MinimizeToTrayCheckBox_Changed"/>
                        <CheckBox x:Name="AutoStartCheckBox" Content="开机自启动"
                                  Checked="AutoStartCheckBox_Changed"
                                  Unchecked="AutoStartCheckBox_Changed"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem x:Name="AboutTabItem" Header="关于">
                <StackPanel Margin="0,8,0,0" Spacing="12">
                    <TextBlock Text="语音输入"
                               FontSize="22" FontWeight="Bold"/>
                    <TextBlock x:Name="VersionText"
                               Foreground="Gray" FontSize="13"/>
                    <TextBlock TextWrapping="Wrap" LineHeight="22" Foreground="#333333">
                        基于 SenseVoice 的本地语音识别工具。<LineBreak/>
                        使用右 Alt 快捷键进行语音输入：<LineBreak/>
                        · 短按：开始/结束长录音<LineBreak/>
                        · 按住：松手结束短句录音
                    </TextBlock>
                    <HyperlinkButton Content="官方文档"
                                     NavigateUri="https://my.feishu.cn/wiki/EyJswQiaBiaOlzkguzPc52mAn8b?from=from_copylink"
                                     HorizontalAlignment="Left"/>
                    <HyperlinkButton Content="https://github.com/pengcunfu/sigxor"
                                     NavigateUri="https://github.com/pengcunfu/sigxor"
                                     HorizontalAlignment="Left"/>
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
